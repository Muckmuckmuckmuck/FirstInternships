# ── Supabase ────────────────────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=        # server only — never ship to the client
VITE_SUPABASE_URL=                # client (anon)
VITE_SUPABASE_ANON_KEY=

# ── Google OAuth (Gmail send) ───────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=              # e.g. https://firstinternships.com/api/auth-google
VITE_GOOGLE_CLIENT_ID=
VITE_GOOGLE_REDIRECT_URI=

# ── Gemini ──────────────────────────────────────────────────────────────────
GEMINI_API_KEY=                   # server only

# ── Stripe ──────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=              # $20/mo recurring price
STRIPE_TOPUP_PRICE_ID=           # $5 / 100-credit one-time price

# ── App ─────────────────────────────────────────────────────────────────────
APP_URL=https://firstinternships.com
CRON_SECRET=                      # random string; guards /api/process-queue
